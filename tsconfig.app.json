{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",

    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],

    "module": "ESNext",

    "moduleResolution": "bundler",

    "paths": {
      "@/*": ["./src/*"]
    },

    "types": ["vite/client"],

    "jsx": "react-jsx",

    "strict": true,

    "skipLibCheck": true,

    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",

    "noEmit": true
  },

  "include": ["src"]
}
